{
    "extends": "./tsconfig.base.json",
    "compilerOptions": {
        "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.app.tsbuildinfo",
        "noEmit": true,
        "jsx": "react-jsx",
        "paths": {
            "@pipewave/core": [
                "./packages/core/src/index.ts"
            ],
            "@pipewave/react": [
                "./packages/react/src/index.ts"
            ],
            "@pipewave/vue": [
                "./packages/vue/src/index.ts"
            ],
            "@pipewave/vanilla": [
                "./packages/vanilla/src/index.ts"
            ]
        }
    },
    "include": [
        "src"
    ]
}