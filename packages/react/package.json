{
    "name": "@pipewave/react",
    "description": "React adapter for the Pipewave client SDK.",
    "version": "0.0.1",
    "type": "module",
    "main": "./dist/index.es.js",
    "module": "./dist/index.es.js",
    "types": "./dist/index.d.ts",
    "repository": {
        "type": "git",
        "url": "git+https://https://github.com/pipewave-dev/node-client.git"
    },
    "homepage": "https://https://github.com/pipewave-dev/node-client",
    "bugs": {
        "url": "https://https://github.com/pipewave-dev/node-client/issues"
    },
    "files": [
        "dist"
    ],
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.es.js"
        }
    },
    "publishConfig": {
        "access": "public"
    },
    "scripts": {
        "build": "vite build --config vite.config.ts",
        "typecheck": "tsc -p tsconfig.json --noEmit"
    },
    "peerDependencies": {
        "react": "^19.0.0 || ^20.0.0",
        "react-dom": "^19.0.0 || ^20.0.0"
    },
    "dependencies": {
        "@pipewave/core": "workspace:^"
    },
    "keywords": [
        "pipewave",
        "sdk",
        "react",
        "websocket",
        "realtime"
    ],
    "sideEffects": false
}